# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# .env wird NICHT ins Git committed (siehe .gitignore)!

# ─── Source PostgreSQL ────────────────────────────────────────────────────────
SOURCE_PG_DB=sourcedb
SOURCE_PG_USER=sourceuser
SOURCE_PG_PASSWORD=sourcepassword

# ─── Destination PostgreSQL ───────────────────────────────────────────────────
DEST_PG_DB=destdb
DEST_PG_USER=destuser
DEST_PG_PASSWORD=destpassword

# ─── Destination MySQL ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
DEST_MYSQL_DB=destdb
DEST_MYSQL_USER=destuser
DEST_MYSQL_PASSWORD=destpassword
